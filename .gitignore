# --- SUMO / TraCI / Simulation Artifacts ---
*.log
*.pb
*.dump
*.bak
*~
# Ignore dynamically generated traffic files
# (Keep your .net.xml and base .rou.xml manually)
*.trips.xml
*.rou.alt.xml
# Per-worker route files generated at runtime by the traffic generators
dynamic.rou.xml
dynamic_worker_*.rou.xml
# Raw OSM extracts (large, re-fetchable via each scenario's BUILD notes)
*.osm.xml

# --- Python & Virtual Environments ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
build/
dist/

# --- RL Training & Models ---
*.zip
*.pkl
*.pt
logs/
tensorboard_logs/
results/
models/

# --- IDEs & OS Junk ---
.vscode/
.idea/
.DS_Store
Thumbs.db

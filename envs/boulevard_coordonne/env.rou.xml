<routes>
    <!-- Définition du type de véhicule standard -->
    <vType id="voiture_walid" vClass="passenger" length="5.0" maxSpeed="13.89" sigma="0.5"/>

    <!-- Itinéraire reliant le début de la grille à la fin (de l'ouest vers l'est) -->
    <!-- Note : netgenerate crée par défaut des arrêtes nommées selon les coordonnées des nœuds -->
    <route id="route_directe" edges="0_0to1_0 1_0to2_0 2_0to3_0"/>

    <!-- Injection d'un flux continu de véhicules : 1 voiture toutes les 3 secondes -->
    <flow id="flux_boulevard" type="voiture_walid" route="route_directe" begin="0" end="3600" period="3"/>
</routes>
